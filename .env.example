# ============================================================
#  Acadly — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# ---- Server ----
PORT=3000

# ---- MySQL Database (MySQL Workbench / MySQL Community Server) ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=acadly_db

# ---- Admin Panel Secret ----
# Set a long random string — this key is required in the x-admin-key header
# to access any /api/admin route.
ADMIN_SECRET_KEY=replace-this-with-a-long-random-secret